# Gunimi — Environment Variables
# Copy this file to .env.local and fill in all required values.
# Never commit .env.local to git.
#
# Key: REQUIRED = deployment fails without this
#      OPTIONAL = feature disabled if missing (see notes)

# ─────────────────────────────────────────────────────────────
# SUPABASE (REQUIRED)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# APPLICATION (REQUIRED)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://gunimi.com
OAUTH_STATE_SECRET=                     # 32+ char random secret — generate fresh for each environment

# ─────────────────────────────────────────────────────────────
# CRON (REQUIRED for signal scanning)
# ─────────────────────────────────────────────────────────────
# Must match the value set in Vercel → Project → Settings → Environment Variables.
# Used by /api/cron/scan to validate Vercel Cron invocations.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─────────────────────────────────────────────────────────────
# EMAIL — POSTMARK (OPTIONAL — email disabled if missing)
# ─────────────────────────────────────────────────────────────
POSTMARK_SERVER_TOKEN=
EMAIL_FROM=Gunimi <noreply@gunimi.com>
SUPPORT_EMAIL=support@gunimi.com

# ─────────────────────────────────────────────────────────────
# AI — OPENAI (OPTIONAL — AI features disabled if missing)
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────
# RATE LIMITING — UPSTASH REDIS (OPTIONAL — rate limiting disabled if missing)
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────
# ERROR TRACKING — SENTRY (OPTIONAL — error tracking blind if missing)
# ─────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                      # Source map upload at build time

# ─────────────────────────────────────────────────────────────
# OAUTH — GOOGLE CALENDAR / EMAIL (OPTIONAL — calendar/email OAuth disabled if missing)
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
